-- NVL NULL이 아니면 그대로, NULL이면 지정한 값
SELECT * FROM EMP;
SELECT EMPNO, ENAME, SAL, COMM,
SAL + COMM, NVL(COMM, 0), SAL + NVL(COMM, 0) FROM EMP;
-- NVL2 NULL이 아닐때와 NULL일때 각각 지정한 값
SELECT EMPNO, ENAME, COMM, 
NVL2(COMM, 'O', 'X'),
NVL2(COMM, SAL*12 + COMM, SAL*12) AS ANNSAL
FROM EMP;

-- DECODE 기준 데이터에 따라 반환할 데이터 지정
SELECT * FROM EMP;
SELECT EMPNO, ENAME, JOB, SAL, DECODE(JOB,
'MANAGER', SAL*1.1,
'SALESMAN', SAL*1.05,
'ANALYST', SAL, SAL*1.03) AS UPSAL
FROM EMP;

-- CASE~END 선택문
SELECT * FROM EMP;
-- 기준 데이터를 지정하는 방식
SELECT EMPNO, ENAME, JOB, SAL, CASE JOB
WHEN 'MANAGER' THEN SAL*1.1
WHEN 'SALESMAN' THEN SAL*1.05
WHEN 'ANALYST' THEN SAL ELSE SAL*1.03
END AS UPSAL
FROM EMP;
-- 기준 데이터를 지정하지 않는 방식
SELECT EMPNO, ENAME, COMM, CASE
WHEN COMM IS NULL THEN '해당사항 없음'
WHEN COMM = 0 THEN '수당없음'
WHEN COMM > 0 THEN '수당:' || COMM
END AS COMM_TEXT
FROM EMP;

