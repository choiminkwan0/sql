SELECT PROD_NAME AS "상품 명", CATEGORY AS "카테고리", PRICE AS "단가"
FROM SHOP_PRODUCT
GROUP BY PROD_NAME, CATEGORY, PRICE
ORDER BY PRICE;

SELECT AVG(PRICE) AS "평균 단가", CATEGORY AS "카테고리"
FROM SHOP_PRODUCT
GROUP BY CATEGORY
HAVING AVG(PRICE) >= 500000
ORDER BY CATEGORY;

SELECT AVG(PRICE) AS "전체 평균 단가"
FROM SHOP_PRODUCT;

SELECT PROD_NAME AS "상품 명", PRICE AS "단가"
FROM SHOP_PRODUCT
WHERE PRICE > (SELECT AVG(PRICE) FROM SHOP_PRODUCT);

SELECT * FROM SHOP_PRODUCT;

UPDATE SHOP_PRODUCT
SET PRICE = PRICE * 1.1
WHERE STOCK < 10;

SELECT PROD_ID AS "상품 번호", PROD_NAME AS "상품 명", CATEGORY AS "카테고리",
PRICE AS "단가", STOCK AS "재고 수량", REG_DATE AS "등록일" 
FROM SHOP_PRODUCT;

SELECT PROD_ID AS "상품 번호", PROD_NAME AS "상품 명", CATEGORY AS "카테고리",
PRICE AS "단가", STOCK AS "재고 수량", REG_DATE AS "등록일"
FROM SHOP_PRODUCT
WHERE PROD_NAME LIKE 'S%' OR CATEGORY LIKE '생활';

CREATE OR REPLACE PROCEDURE PROC_ADD_PRICE
(
p_id IN NUMBER,
p_amount IN NUMBER
)
IS
BEGIN
DBMS_OUTPUT.PUT_LINE('p_id:' || p_id);
DBMS_OUTPUT.PUT_LINE('p_amount:' || p_amount);
DBMS_OUTPUT.PUT_LINE('가격 수정 완료');
END;

UPDATE SHOP_PRODUCT 
SET PRICE = PRICE + p_amount 
WHERE SHOP_PRODUCT = PRICE;
EXECUTE PROC_ADD_PRICE(1, 8000);
COMMIT;

