CREATE TABLE SHOP_PRODUCT(
PROD_ID     NUMBER(4)       PRIMARY KEY,
PROD_NAME   VARCHAR2(50)    NOT NULL,
CATEGORY    VARCHAR2(20),
PRICE       NUMBER(10)      CHECK(PRICE>0),
STOCK       NUMBER(5),
REG_DATE    DATE            DEFAULT SYSDATE
);

