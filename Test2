CREATE TABLE MEMBER_TABLE(
USER_ID         VARCHAR2(20)     PRIMARY KEY,
USER_PW         VARCHAR2(20)     NOT NULL,
USER_NAME       VARCHAR2(20)      NOT NULL,
USER_TEL        VARCHAR2(20)     NOT NULL,  
USER_DATE       DATE             DEFAULT SYSDATE,
USER_RENTAL     VARCHAR(10)
);
SELECT * FROM MEMBER_TABLE;

ALTER TABLE MEMBER_TABLE
MODIFY USER_RENTAL DEFAULT NULL;

CREATE TABLE BOOK_TABLE(
BOOK_PK         NUMBER(4)        PRIMARY KEY,
ISBN            NUMBER(4)        UNIQUE,
BOOK_NAME       VARCHAR2(30)     NOT NULL,
AUTHOR          VARCHAR2(20)     NOT NULL, 
PUBLISHER       VARCHAR2(20)     NOT NULL,
BOOK_RENTAL     VARCHAR2(10)          
);
SELECT * FROM BOOK_TABLE;

CREATE TABLE RENTAL_TABLE(
RENTAL_PK       NUMBER(4)       PRIMARY KEY,      
USER_ID         VARCHAR2(20)    CONSTRAINT FK_RENTAL_USER 
                                REFERENCES MEMBER_TABLE(USER_ID),
BOOK_PK         NUMBER(4)       CONSTRAINT FK_RENTAL_BOOK 
                                REFERENCES BOOK_TABLE(BOOK_PK),
RENTAL_DATE     DATE            DEFAULT SYSDATE,
RETURN_SCHEDULE DATE            DEFAULT SYSDATE,
RETURN_DATE     DATE            DEFAULT SYSDATE,
OVERDUE         VARCHAR2(10)
);
SELECT * FROM RENTAL_TABLE;

CREATE OR REPLACE FUNCTION USER_LOGIN (
    a_userid    MEMBER_TABLE.USER_ID%TYPE,
    a_userpw    MEMBER_TABLE.USER_PW%TYPE
) RETURN PLS_INTEGER
IS
    v_userpw MEMBER_TABLE.USER_PW%TYPE;
    v_result PLS_INTEGER;
BEGIN
    SELECT USER_PW INTO v_userpw
    FROM MEMBER_TABLE
    WHERE USER_ID = a_userid;
    
    IF v_userpw = a_userpw THEN
        RETURN 0;
    ELSE
        RETURN 1;
    END IF;
EXCEPTION
    WHEN NO_DATA_FOUND THEN
    RETURN 2;
END;
/
