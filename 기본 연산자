select * from emp; 
// * 전체 열 출력
select ename from emp;
// 부분 열 출력
select empno, ename from emp;
// 중복 출력
select distinct job from emp;
// distinct 열 중복 제거
select job from emp;

select job as a from emp;
// as a a로 별칭 지정
select * from dept;

select * from dept where deptno = 30;

select * from dept where deptno = 30 and dname ='SALES';
// and 둘다 true여야 true
select * from emp where deptno = 30 or job ='CLERK';
// or 하나만 true여도 true
select * from emp where sal >= 3000;

select * from emp where ename >='F';

select * from emp where sal != 3000;
// != 같지않다
select * from emp where sal <> 3000;
// <> 같지않다
select * from emp where not sal = 3000;
// not 논리 부정 연산자

select * from emp where job in('MANAGER', 'SALESMAN', 'CLERK');
select * from emp where job ='MANAGER' or job ='SALESMAN' or job ='CLERK';

select * from emp where sal between 2000 and 3000;

select * from emp where sal not between 2000 and 3000;

select * from emp;

select * from emp where ename like 'S%'; // S로 시작하는 모든 데이터
select * from emp where ename like '_L%'; // 두번째 글자가L인 모든 데이터
select * from emp where ename like '%AM%'; // AM을 포함한 모든 데이터
select * from emp where ename not like '%AM%';
// _ 한개의 문자 데이터
// % 길이와 상관없이 모든 문자 데이터

select * from emp where comm is null;
select * from emp where mgr is not null;




