-- UNION 중복이 제거되는 합집합(두 컬럼이 서로 같아야함)
SELECT * FROM EMP;
SELECT EMPNO, ENAME, SAL, DEPTNO
FROM EMP
WHERE DEPTNO = 10
UNION
SELECT EMPNO, ENAME, SAL, DEPTNO
FROM EMP
WHERE DEPTNO = 20;

-- UNION ALL 중복을 허용하는 합집합
SELECT * FROM EMP;
SELECT EMPNO, ENAME, SAL, DEPTNO
FROM EMP
WHERE DEPTNO = 10
UNION ALL
SELECT EMPNO, ENAME, SAL, DEPTNO
FROM EMP
WHERE DEPTNO = 10;

-- MINUS 차집합
SELECT * FROM EMP;
SELECT EMPNO, ENAME, SAL, DEPTNO
FROM EMP
MINUS
SELECT EMPNO, ENAME, SAL, DEPTNO
FROM EMP
WHERE DEPTNO = 10;

-- INTERSECT 교집합
SELECT * FROM EMP;
SELECT EMPNO, ENAME, SAL, DEPTNO
FROM EMP
INTERSECT
SELECT EMPNO, ENAME, SAL, DEPTNO
FROM EMP
WHERE DEPTNO = 10;

-- UPPER(전체 대문자), LOWER(전체 소문자), INITCAP(첫글자만 대문자) 대소문자변환
SELECT * FROM EMP;
SELECT ENAME, UPPER(ENAME), LOWER(ENAME), INITCAP(ENAME) FROM EMP;

-- LENGTH 문자열 길이
SELECT * FROM EMP;
SELECT ENAME, LENGTH(ENAME) FROM EMP;
SELECT ENAME, LENGTH(ENAME) FROM EMP WHERE LENGTH(ENAME) >= 5;

-- SUBSTR 문자열 일부 추출
-- SUBSTR(문자열 데이터, 시작위치, 추출길이) SUBSTR(문자열 데이터, 시작위치) < 끝까지 읽음
SELECT * FROM EMP;
SELECT JOB, SUBSTR(JOB, 1, 2), SUBSTR(JOB, 3, 2), SUBSTR(JOB, 5) FROM EMP;

-- INSTR 문자열 데이터 내 특정 문자 위치 찾기
SELECT * FROM EMP;
SELECT *
FROM EMP
WHERE INSTR(ENAME, 'S') > 0;

-- REPLACE 특정 문자를 다른 문자로 대체
-- REPLACE(대상 문자열, 찾을 문자, 바꿀 문자) 바꿀 문자 생략시 찾을 문자 삭제
SELECT '010-1234-5678' AS REPLACE_BEFORE,
REPLACE('010-1234-5678', '-',' ')AS REPLACE_1,
REPLACE('010-1234-5678', '-')AS REPLACE_2 FROM DUAL;

-- LPAD, RPAD 데이터의 빈 공간 채우기
-- LPAD, RPAD(문자, 전체길이, 남는공간에 채울 문자) 채울 문자 생략 시 공백이 채워짐
SELECT 'Oracle',
LPAD('Oracle', 10, '#') AS LPAD_1,
RPAD('Oracle', 10, '*') AS RPAD_1,
LPAD('Oracle', 10) AS LPAD_2,
RPAD('Oracle', 10) AS RPAD_2 FROM DUAL;

-- CONCAT 두 문자열 데이터 합치기
SELECT * FROM EMP;
SELECT CONCAT(EMPNO, ENAME),
CONCAT(EMPNO,CONCAT(':', ENAME))
FROM EMP
WHERE ENAME = 'SCOTT';

-- ROUND 반올림 TRUNC 버림
SELECT ROUND(1234.5678) AS ROUND,
ROUND(1234.5678, 0) AS ROUND_0, -- 소수점 첫째자리에서 반올림
TRUNC(1234.5678, 1) AS ROUND_1, -- 소수점 둘째자리에서 버림
ROUND(1234.5678, 2) AS ROUND_2, -- 소수점 셋째자리에서 반올림
TRUNC(1234.5678, -1) AS ROUND_MINUS1, -- 1의 자리에서 버림
ROUND(1234.5678, -2) AS ROUND_MINUS2 FROM DUAL; -- 10의 자리에서 반올림

-- CEIL 올림 FLOOR 버림
SELECT CEIL(3.14),
FLOOR(3.14),
CEIL(-3.14),
FLOOR(-3.14)
FROM DUAL;

-- MOD 숫자를 나눈 나머지
SELECT MOD(15, 6), MOD(10, 2), MOD(11, 2) FROM DUAL;

-- SYSDATE 현재 날짜와 시간
SELECT SYSDATE AS NOW,
SYSDATE -1 AS YESTERDAY,
SYSDATE +1 AS TOMORROW FROM DUAL;

-- ADD_MONTHS 몇 개월 이후 날짜
SELECT SYSDATE,
ADD_MONTHS(SYSDATE, 3) 
FROM DUAL;

-- 근속 연수가 32년이 되지 않은 직원들을 조회
SELECT * FROM EMP;
SELECT EMPNO, ENAME, HIREDATE, SYSDATE
FROM EMP
WHERE ADD_MONTHS(HIREDATE, 384) > SYSDATE;

-- MONTHS BETWEEN 두 날짜 간의 개월수 차이
SELECT * FROM EMP;
SELECT EMPNO, ENAME, HIREDATE, SYSDATE,
MONTHS_BETWEEN(HIREDATE, SYSDATE)
AS MONTHS1,
MONTHS_BETWEEN(SYSDATE, HIREDATE)
AS MONTHS2,
TRUNC(MONTHS_BETWEEN(SYSDATE, HIREDATE))
AS MONTHS3 FROM EMP;

-- TO_CHAR 숫자 또는 날짜 데이터를 문자 데이터로 변환
SELECT SYSDATE,
TO_CHAR(SYSDATE, 'HH24:MI:SS') AS HH24MISS,
TO_CHAR(SYSDATE, 'HH12:MI:SS AM') AS HHMISS_AM,
TO_CHAR(SYSDATE, 'HH24:MI:SS P.M.') AS HHMISS_PM FROM DUAL;

-- TO_NUMBER 문자 데이터를 숫자 데이터로 변환
SELECT TO_NUMBER('1,300', '999,999') - TO_NUMBER('1,500', '999,999') FROM DUAL;

-- TO_DATE 문자 데이터를 날짜 데이터로 변환
SELECT * FROM EMP;
SELECT TO_DATE('2018-07-14', 'YYYY-MM-DD') AS TODATE1,
TO_DATE('20180714', 'YYYY-MM-DD') AS TODATE2 FROM DUAL;

SELECT * FROM EMP WHERE HIREDATE > TO_DATE('1981/06/01', 'YYYY/MM/DD');

-- 조인 관계가 형성 할 수 없으면 조인 할 수 없다
-- 조인은 왼쪽이 기준
SELECT * FROM EMP E, DEPT D
WHERE E.DEPTNO = D.DEPTNO
ORDER BY EMPNO;

SELECT * FROM EMP;
SELECT * FROM DEPT;
SELECT E.EMPNO, E.ENAME, E.SAL, D.DEPTNO, D.DNAME, D.LOC
FROM EMP E, DEPT D
WHERE E.DEPTNO = D.DEPTNO
AND SAL >= 3000;

SELECT * FROM EMP;
SELECT * FROM SALGRADE;
SELECT *
FROM EMP E, SALGRADE S
WHERE E.SAL BETWEEN S.LOSAL AND S.HISAL;

-- 셀프조인
SELECT * FROM EMP;
SELECT E1.EMPNO, E1.ENAME, E1.MGR, 
E2.EMPNO AS MGR_EMPNO,
E2.ENAME AS MGR_ENAME
FROM EMP E1, EMP E2
WHERE E1.MGR = E2.EMPNO;

-- NATURAL JOIN 필드의 중복을 최소화
SELECT * FROM EMP;
SELECT * FROM DEPT;
SELECT E.EMPNO, E.ENAME, E.JOB, E.MGR, E.HIREDATE, E.SAL, E.COMM,
DEPTNO, D.DNAME, D.LOC
FROM EMP E NATURAL JOIN DEPT D
ORDER BY DEPTNO, E.EMPNO;

-- USING 조인에 사용할 기준열 명시
SELECT E.EMPNO, E.ENAME, E.JOB, E.MGR, E.HIREDATE, E.SAL, E.COMM,
DEPTNO, D.DNAME, D.LOC
FROM EMP E JOIN DEPT D USING(DEPTNO)
WHERE SAL >= 3000
ORDER BY DEPTNO, E.EMPNO;

-- ON 비교 연산자를 사용한 조건식 명시
SELECT E.EMPNO, E.ENAME, E.JOB, E.MGR, E.HIREDATE, E.SAL, E.COMM,
D.DNAME, D.LOC
FROM EMP E JOIN DEPT D ON(E.DEPTNO = D.DEPTNO)
WHERE SAL <= 3000
ORDER BY E.DEPTNO, EMPNO;

-- OUTER JOIN 외부 조인
-- LEFT(왼쪽), RIGHT(오른쪽) OUTER JOIN 조인을 한 뒤 빈 공간을 채워 넣음
SELECT E1.EMPNO, E1.ENAME, E1.MGR,
E2.EMPNO AS MGR_EMPNO, E2.ENAME AS MGR_ENAME
FROM EMP E1 LEFT OUTER JOIN EMP E2 ON(E1.MGR = E2.EMPNO)
ORDER BY E1.EMPNO;

